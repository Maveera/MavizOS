# live-build configuration for MavizOS live ISO
# Consumed by install/iso/build-iso.sh

lb config noauto \
  --architectures amd64 \
  --distribution bookworm \
  --linux-flavours amd64 \
  --archive-areas "main contrib non-free non-free-firmware" \
  --debian-installer false \
  --iso-application "MavizOS AI SOC OS" \
  --iso-preparer "MavizOS Project" \
  --iso-publisher "MavizOS" \
  --iso-volume "MAVIZOS" \
  --memtest none \
  --win32-loader false \
  --bootappend-live "boot=live components quiet splash"
